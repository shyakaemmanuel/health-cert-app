# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT (copy to `.env` for local dev)
# ============================================
# Backend port for local dev
PORT=5000
# NODE_ENV for local dev
NODE_ENV=development
# Short dev secret (CHANGE in production)
JWT_SECRET=dev-secret-change-in-production
# Local Postgres connection (example)
DATABASE_URL=postgres://postgres:123@localhost:5432/health_cert_app
# Frontend origin used for CORS when running frontend dev server
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_DEV=http://localhost:5173
# Logging level for local development
LOG_LEVEL=debug

# ============================================
# PRODUCTION ENVIRONMENT
# DO NOT commit production secrets. Set these in Railway / Vercel dashboards.
# ============================================
# Backend (Railway):
# NODE_ENV=production
# PORT is provided by Railway; do not hardcode
# JWT_SECRET: a long random string (e.g. openssl rand -hex 32)
# DATABASE_URL: provided by Railway PostgreSQL plugin
# FRONTEND_URL: https://<your-vercel-frontend-url>
# LOG_LEVEL=info

# Frontend (Vercel):
# VITE_API_URL: https://<your-railway-backend-url>  # build-time API base URL

# Tips:
# - Set `VITE_API_URL` in the Vercel frontend environment before building the site.
# - Use secure secrets for `JWT_SECRET` and never commit `.env` to git.
