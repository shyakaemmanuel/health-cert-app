# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT (copy to `.env` for local dev)
# ============================================
# Backend port for local dev
PORT=5000
# NODE_ENV for local dev
NODE_ENV=development
# Short dev secret (CHANGE in production)
JWT_SECRET=dev-secret-change-in-production
# Local Postgres connection (example)
DATABASE_URL=postgres://postgres:123@localhost:5432/health_cert_app
# Frontend origin used for CORS when running frontend dev server
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_DEV=http://localhost:5173
# Logging level for local development
LOG_LEVEL=debug

# ============================================
# PRODUCTION (RENDER) ENVIRONMENT
# DO NOT commit production secrets. Set these in Render Dashboard.
# ============================================
# NODE_ENV=production
# PORT is set by Render; do not hardcode
# JWT_SECRET: a long random string (e.g. openssl rand -hex 32)
# DATABASE_URL: auto-provided by Render Postgres service (see render.yaml)
# FRONTEND_URL: https://<your-frontend-service>.onrender.com
# BACKEND_URL: https://<your-backend-service>.onrender.com
# VITE_API_URL: https://<your-backend-service>.onrender.com  # build-time for the frontend
# LOG_LEVEL=info

# Tips:
# - Ensure `VITE_API_URL` is set in the Render frontend service BEFORE it builds the static site.
# - Never expose `JWT_SECRET` or `DATABASE_URL` publicly or commit them to git.
